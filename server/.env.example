# =============================================================================
# GSD Cloud Server Configuration
# =============================================================================
# Copy this file to .env and edit the values below.
# Required variables are marked with [REQUIRED].
# =============================================================================

# --- Domain & Environment ---

# [REQUIRED] Domain name for the server (used by Traefik for TLS)
DOMAIN=localhost

# [REQUIRED] URL where the frontend is served from
# In production with Nginx frontend: http://frontend (Docker internal)
# In local dev: http://localhost:5173
FRONTEND_HOST=http://localhost:5173

# Environment mode: local, staging, or production
ENVIRONMENT=local

# Project display name
PROJECT_NAME="GSD Cloud"

# Docker Compose stack name
STACK_NAME=gsd-cloud

# --- Authentication ---

# [REQUIRED] Secret key for JWT signing -- CHANGE THIS in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis

# [REQUIRED] Initial admin account email
FIRST_SUPERUSER=admin@example.com

# [REQUIRED] Initial admin account password -- CHANGE THIS in production
FIRST_SUPERUSER_PASSWORD=changethis

# --- CORS ---

# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# --- PostgreSQL ---

# [REQUIRED] PostgreSQL connection details
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
# [REQUIRED] Database password -- CHANGE THIS in production
POSTGRES_PASSWORD=changethis

# --- Redis ---

# Redis URL for WebSocket pub/sub fan-out (multi-worker support)
# Leave empty or unset to use in-memory only (single-worker mode)
REDIS_URL=redis://redis:6379/0

# --- Email (optional) ---

# SMTP configuration for sending emails (password reset, etc.)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587
EMAILS_FROM_EMAIL=info@example.com

# --- Observability (optional) ---

# Sentry DSN for error tracking
SENTRY_DSN=

# --- Docker Images ---

# Docker image names (used by docker-compose build)
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
